#!/usr/bin/env bash
# Source this script to load infra env vars into your shell:
#   source load-infra-env
#
# Self-contained: derives DATA_DIR and port-file paths from the script's
# location so it works in tmux windows / subshells that didn't inherit the
# nix-shell environment.

_script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
_repo_root="$(cd "$_script_dir/.." && pwd)"

if [ -z "${DATA_DIR:-}" ]; then
  export DATA_DIR="$_repo_root/.data"
fi

export MINIO_API_PORT_FILE="${MINIO_API_PORT_FILE:-$DATA_DIR/minio/api_port}"
export RABBITMQ_AMQP_PORT_FILE="${RABBITMQ_AMQP_PORT_FILE:-$DATA_DIR/rabbitmq/amqp_port}"
export PROXY_PORT_FILE="${PROXY_PORT_FILE:-$DATA_DIR/caddy/port}"

# MinIO
if [ -f "$MINIO_API_PORT_FILE" ]; then
  export MINIO_PORT=$(cat "$MINIO_API_PORT_FILE")
  export MINIO_URL="http://127.0.0.1:$MINIO_PORT"
  export STORAGE_S3_ENDPOINT="$MINIO_URL"
  export STORAGE_S3_ACCESS_KEY=minioadmin
  export STORAGE_S3_SECRET_KEY=minioadmin
  export STORAGE_S3_BUCKET=reliquary
  echo "MINIO_URL=$MINIO_URL"
fi

# RabbitMQ
if [ -f "$RABBITMQ_AMQP_PORT_FILE" ]; then
  export RABBITMQ_AMQP_PORT=$(cat "$RABBITMQ_AMQP_PORT_FILE")
  export RABBITMQ_URL="amqp://guest:guest@127.0.0.1:$RABBITMQ_AMQP_PORT"
  echo "RABBITMQ_AMQP_PORT=$RABBITMQ_AMQP_PORT"
  echo "RABBITMQ_URL=$RABBITMQ_URL"
fi

# Proxy (Caddy)
if [ -f "$PROXY_PORT_FILE" ]; then
  export PROXY_PORT=$(cat "$PROXY_PORT_FILE")
  echo "PROXY_PORT=$PROXY_PORT"
fi

# Engram backend URL (proxied by Caddy) and presign URL template used by
# Engram to render download_url for s3-backed files.
if [ -n "${PROXY_PORT:-}" ]; then
  export ENGRAM_URL="http://localhost:$PROXY_PORT/api/engram"
  export RELIQUARY_URL="http://localhost:$PROXY_PORT/api/reliquary"
  export PRESIGN_URL_TEMPLATE="$RELIQUARY_URL/api/files/presign?key={file_path}"
  echo "ENGRAM_URL=$ENGRAM_URL"
  echo "RELIQUARY_URL=$RELIQUARY_URL"
fi

# PostgreSQL
export PGHOST="$DATA_DIR/postgres"
echo "PGHOST=$PGHOST"

# Authentik
AUTHENTIK_SERVER_PORT_FILE="$DATA_DIR/authentik/server_port"
if [ -f "$AUTHENTIK_SERVER_PORT_FILE" ]; then
  export AUTHENTIK_PORT=$(cat "$AUTHENTIK_SERVER_PORT_FILE")
  export AUTHENTIK_URL="http://127.0.0.1:$AUTHENTIK_PORT"
  echo "AUTHENTIK_URL=$AUTHENTIK_URL"

  # Reliquary OIDC auth — validates Bearer tokens against Authentik's
  # userinfo endpoint.
  export AUTH_MODE=oidc
  export OIDC_ISSUER_URL="$AUTHENTIK_URL/application/o/mind-palace/"
  export OIDC_CLIENT_ID=mind-palace
  echo "OIDC_ISSUER_URL=$OIDC_ISSUER_URL"
fi
