#!/usr/bin/env bash
# Source this script to load infra env vars into your shell:
#   source load-infra-env

if [ -z "${DATA_DIR:-}" ]; then
  echo "ERROR: DATA_DIR is not set. Are you in the dev shell? (nix develop)" >&2
  return 1 2>/dev/null || exit 1
fi

# MinIO / S3
if [ -f "$MINIO_API_PORT_FILE" ]; then
  export MINIO_API_PORT=$(cat "$MINIO_API_PORT_FILE")
  export S3_ENDPOINT="http://127.0.0.1:$MINIO_API_PORT"
  export S3_ACCESS_KEY="minioadmin"
  export S3_SECRET_KEY="minioadmin"
  export S3_BUCKET="mind-palace-data"
  echo "S3_ENDPOINT=$S3_ENDPOINT"
  echo "S3_BUCKET=$S3_BUCKET"
fi

# Authentik
if [ -f "$AUTHENTIK_SERVER_PORT_FILE" ]; then
  export AUTHENTIK_PORT=$(cat "$AUTHENTIK_SERVER_PORT_FILE")
  export AUTHENTIK_URL="http://127.0.0.1:$AUTHENTIK_PORT"
  echo "AUTHENTIK_URL=$AUTHENTIK_URL"
fi

if [ -f "$AUTHENTIK_PG_SOCKET_DIR_FILE" ]; then
  export AUTHENTIK_PG_SOCKET_DIR=$(cat "$AUTHENTIK_PG_SOCKET_DIR_FILE")
  echo "AUTHENTIK_PG_SOCKET_DIR=$AUTHENTIK_PG_SOCKET_DIR"
fi

if [ -f "$AUTHENTIK_REDIS_PORT_FILE" ]; then
  export AUTHENTIK_REDIS_PORT=$(cat "$AUTHENTIK_REDIS_PORT_FILE")
  echo "AUTHENTIK_REDIS_PORT=$AUTHENTIK_REDIS_PORT"
fi
