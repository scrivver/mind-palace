#!/usr/bin/env bash
set -euo pipefail

if [ -z "${DATA_DIR:-}" ]; then
  echo "ERROR: DATA_DIR is not set. Are you in the dev shell? (nix develop)" >&2
  exit 1
fi

# Check if infra is running before starting backends
if [ ! -f "$MINIO_API_PORT_FILE" ]; then
  echo "ERROR: Infrastructure is not running." >&2
  echo "Please run 'start-infra' in another terminal or tab first." >&2
  exit 1
fi

SESSION="mind-palace"

# Kill existing session if any.
tmux kill-session -t "$SESSION" 2>/dev/null || true

# Load env into current shell to confirm ports are available
source load-infra-env

# 1. Reliquary Backend
tmux new-session -d -s "$SESSION" -n rel-be
tmux send-keys -t "$SESSION:rel-be" "cd reliquary/backend && source ../../bin/load-infra-env && LISTEN_ADDR=$DATA_DIR/reliquary/backend.sock air" Enter

# 2. Engram Backend
tmux new-window -t "$SESSION" -n eng-be
tmux send-keys -t "$SESSION:eng-be" "cd engram/backend && source ../../bin/load-infra-env && PORT=8081 air" Enter

# 3. Engram Ingestion
tmux new-window -t "$SESSION" -n eng-ingest
tmux send-keys -t "$SESSION:eng-ingest" "cd engram/ingestion && source ../../bin/load-infra-env && uv run main.py" Enter

# 4. Synapse Worker
tmux new-window -t "$SESSION" -n syn-worker
tmux send-keys -t "$SESSION:syn-worker" "cd synapse && source ../bin/load-infra-env && go run ./cmd/synapse-worker" Enter

# 5. Mind Palace App (Desktop)
tmux new-window -t "$SESSION" -n app
tmux send-keys -t "$SESSION:app" "start-app" Enter

# Select first window and attach.
tmux select-window -t "$SESSION:rel-be" 2>/dev/null || true
echo "Backends and Frontends launched in tmux session: $SESSION"
echo "Ensure 'start-infra' is running in the background."
exec tmux attach-session -t "$SESSION"
